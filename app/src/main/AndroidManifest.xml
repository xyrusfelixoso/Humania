            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyDFLF588c4VP5vRxPXIaCDd2KSyXOgjQKA" />

        <activity
            android:name=".Splashscreen"
            android:exported="true"
            android:theme="@style/Theme.Humania">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".btn"
            android:exported="false" />

        <activity
            android:name=".MainActivity"
            android:exported="false"/>
        <activity
            android:name=".SignUpActivity"
            android:exported="false"/>
        <activity
            android:name=".activity_getstarted"
            android:exported="false"/>
        <activity
            android:name=".activity_onboarding"
            android:exported="false"/>

        <activity
            android:name=".DonateActivity"
            android:exported="false"/>
        <activity
            android:name=".HomeActivity"
            android:exported="false"/>
        <activity
            android:name=".ProfileActivity"
            android:exported="false"/>
        <activity
            android:name=".DetailActivity"
            android:exported="false"/>
        <activity
            android:name=".ChatActivity"
            android:exported="false"/>
        <activity
            android:name=".BrowseActivity"
            android:exported="false"/>
        <activity
            android:name=".MessageListActivity"
            android:exported="false"/>
        <activity
            android:name=".MyDonationsActivity"
            android:exported="false"/>
        <activity
            android:name=".MapPickerActivity"
            android:exported="false"/>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>


    </application>

</manifest>
