<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_home.xml -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── HEADER ── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_home"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="56dp"
                android:paddingBottom="48dp">

                <!-- Greeting + Name -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/good_morning"
                        android:textColor="@color/white_60"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/user_name_default"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="serif" />

                    <!-- Stats Row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="20dp">

                        <!-- Stat: Donated -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/bg_stat_pill"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:layout_marginEnd="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/stat_donated"
                                android:textColor="@color/white_60"
                                android:textSize="11sp"
                                android:letterSpacing="0.05" />
                        </LinearLayout>

                        <!-- Stat: Families -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/bg_stat_pill"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:layout_marginEnd="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="48"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/stat_helped"
                                android:textColor="@color/white_60"
                                android:textSize="11sp"
                                android:letterSpacing="0.05" />
                        </LinearLayout>

                        <!-- Stat: Rating -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/bg_stat_pill"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⭐ 4.9"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/stat_rating"
                                android:textColor="@color/white_60"
                                android:textSize="11sp"
                                android:letterSpacing="0.05" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>

                <!-- Avatar -->
                <FrameLayout
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_gravity="top|end"
                    android:background="@drawable/bg_avatar"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/default_avatar_emoji"
                        android:textSize="20sp" />
                </FrameLayout>

            </FrameLayout>

            <!-- ── BODY ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:paddingBottom="96dp">

                <!-- Category Chips (Horizontal Scroll) -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chipAll"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/chip_all"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:background="@drawable/bg_chip_active"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/chipFood"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/chip_food"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:background="@drawable/bg_chip"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/chipClothes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/chip_clothes"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:background="@drawable/bg_chip"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/chipItems"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/chip_items"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:background="@drawable/bg_chip"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/chipToys"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/chip_toys"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:background="@drawable/bg_chip"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp" />

                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Section Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        style="@style/Widget.Humania.SectionTitle"
                        android:text="@string/near_you" />

                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvSeeAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/see_all"
                        android:textColor="@color/green_medium"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Donation Cards -->
                <!-- Card 1 -->
                <include layout="@layout/item_donation_card"
                    android:id="@+id/card1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"/>

                <!-- Card 2 -->
                <include layout="@layout/item_donation_card"
                    android:id="@+id/card2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"/>

                <!-- Card 3 -->
                <include layout="@layout/item_donation_card"
                    android:id="@+id/card3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"/>

                <!-- NOTE: In production, use RecyclerView for dynamic lists -->

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="84dp"
        android:backgroundTint="@color/green_primary"
        android:contentDescription="@string/post_donation"
        app:srcCompat="@android:drawable/ic_input_add"
        app:tint="@color/white"
        app:fabSize="normal"
        app:elevation="8dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
