<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/signup"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_gradient_splash"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="40dp">

        <!-- ── TOP LOGO AREA ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="52dp"
            android:paddingBottom="30dp">

            <!-- Logo Icon -->
            <FrameLayout
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:background="@drawable/bg_splash_icon"
                android:layout_marginBottom="12dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="22dp">
                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:src="@drawable/humanialogo" />
                </androidx.cardview.widget.CardView>
            </FrameLayout>

            <!-- App Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HUMANIA"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:letterSpacing="-0.02" />

        </LinearLayout>

        <!-- ── SIGNUP CARD ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_login_card"
            android:padding="28dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Account"
                android:textColor="#1B4332"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Join our community to start helping others"
                android:textColor="#888888"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="24dp" />

            <!-- ── FULL NAME FIELD ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FULL NAME"
                android:textColor="#52796F"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input"
                    android:hint="John Doe"
                    android:textColorHint="#BBBBBB"
                    android:textColor="#1B4332"
                    android:textSize="14sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:inputType="textPersonName"
                    android:singleLine="true"
                    android:imeOptions="actionNext" />
            </FrameLayout>

            <!-- ── EMAIL FIELD ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMAIL ADDRESS"
                android:textColor="#52796F"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input"
                    android:hint="you@example.com"
                    android:textColorHint="#BBBBBB"
                    android:textColor="#1B4332"
                    android:textSize="14sp"
                    android:paddingStart="48dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:inputType="textEmailAddress"
                    android:singleLine="true"
                    android:imeOptions="actionNext" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="14dp"
                    android:src="@drawable/ic_email"
                    android:contentDescription="Email icon" />
            </FrameLayout>

            <!-- ── PASSWORD FIELD ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PASSWORD"
                android:textColor="#52796F"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input"
                    android:hint="Create a password"
                    android:textColorHint="#BBBBBB"
                    android:textColor="#1B4332"
                    android:textSize="14sp"
                    android:paddingStart="48dp"
                    android:paddingEnd="48dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:inputType="textPassword"
                    android:singleLine="true"
                    android:imeOptions="actionNext" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="14dp"
                    android:src="@drawable/ic_lock"
                    android:contentDescription="Password icon" />
            </FrameLayout>

            <!-- ── CONFIRM PASSWORD FIELD ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONFIRM PASSWORD"
                android:textColor="#52796F"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <EditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input"
                    android:hint="Repeat your password"
                    android:textColorHint="#BBBBBB"
                    android:textColor="#1B4332"
                    android:textSize="14sp"
                    android:paddingStart="48dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:inputType="textPassword"
                    android:singleLine="true"
                    android:imeOptions="actionDone" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="14dp"
                    android:src="@drawable/ic_lock"
                    android:contentDescription="Password icon" />
            </FrameLayout>

            <!-- ── SIGN UP BUTTON ── -->
            <Button
                android:id="@+id/btnSignUp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Create Account"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_primary"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:layout_marginBottom="10dp" />

        </LinearLayout>

        <!-- ── LOGIN LINK ── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? "
                android:textColor="#99FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvLogin"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Sign In"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="15dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
