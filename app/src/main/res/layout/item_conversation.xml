<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_donor_card"
    android:padding="12dp"
    android:layout_marginBottom="12dp"
    android:gravity="center_vertical"
    android:clickable="true"
    android:focusable="true">

    <FrameLayout
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="@drawable/bg_avatar_green">
        <TextView
            android:id="@+id/tvConvAvatarEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="😊"
            android:textSize="24sp" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">
        <TextView
            android:id="@+id/tvConvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User Name"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="16sp" />
        <TextView
            android:id="@+id/tvConvLastMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Last message content..."
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvConvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="10:45 AM"
        android:textColor="@color/text_muted"
        android:textSize="11sp" />
</LinearLayout>
