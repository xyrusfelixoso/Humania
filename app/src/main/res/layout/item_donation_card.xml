<?xml version="1.0" encoding="utf-8"?>
<!-- item_donation_card.xml -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/surface"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Left: Image Area -->
        <FrameLayout
            android:id="@+id/layoutDonationImage"
            android:layout_width="100dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_gradient_card_image"
            android:minHeight="120dp">

            <ImageView
                android:id="@+id/ivDonationImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvDonationEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🎁"
                android:textSize="36sp" />
        </FrameLayout>

        <!-- Right: Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="12dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvDonationTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toStartOf="@+id/btnMessageDonor"
                    android:text="Item Title"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <ImageButton
                    android:id="@+id/btnMessageDonor"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/stat_notify_chat"
                    android:tint="@color/green_primary"
                    android:contentDescription="Message Donor" />

            </RelativeLayout>

            <TextView
                android:id="@+id/tvDonationDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Description goes here..."
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvDonationDonor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="By: Donor Name"
                android:textColor="@color/green_primary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDonationMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Posted 10 min ago"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvTagCategory"
                    style="@style/Widget.Humania.Tag.Green"
                    android:text="Category"
                    android:layout_marginEnd="8dp"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvTagUrgency"
                    style="@style/Widget.Humania.Tag.Orange"
                    android:text="Urgency"
                    android:layout_marginEnd="8dp"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvDistance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0.4 km"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:gravity="end" />

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
