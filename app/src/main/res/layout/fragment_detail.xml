<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_detail.xml -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── HERO IMAGE ── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:background="@drawable/bg_gradient_detail_hero">

                <!-- Item Emoji (replace with ImageView + Glide in production) -->
                <TextView
                    android:id="@+id/tvDetailEmoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🥬"
                    android:textSize="100sp" />

                <!-- Back Button -->
                <FrameLayout
                    android:id="@+id/btnDetailBack"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_gravity="top|start"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="54dp"
                    android:background="@drawable/bg_icon_button"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="←"
                        android:textSize="18sp"
                        android:textColor="@color/text_primary" />
                </FrameLayout>

                <!-- Favorite Button -->
                <FrameLayout
                    android:id="@+id/btnFavorite"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_gravity="top|end"
                    android:layout_marginEnd="20dp"
                    android:layout_marginTop="54dp"
                    android:background="@drawable/bg_icon_button"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tvFavoriteIcon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="🤍"
                        android:textSize="18sp" />
                </FrameLayout>

            </FrameLayout>

            <!-- ── CONTENT ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:paddingBottom="100dp">

                <!-- Title -->
                <TextView
                    android:id="@+id/tvDetailTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Fresh Vegetables Bundle"
                    android:textColor="@color/text_primary"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="serif" />

                <!-- Location -->
                <TextView
                    android:id="@+id/tvDetailLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="📍 0.4 km away · Quezon City"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp" />

                <!-- Tags Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tvDetailTagCategory"
                        style="@style/Widget.Humania.Tag.Green"
                        android:text="🥦 Food" />

                    <View
                        android:layout_width="8dp"
                        android:layout_height="0dp" />

                    <TextView
                        android:id="@+id/tvDetailTagUrgency"
                        style="@style/Widget.Humania.Tag.Orange"
                        android:text="⚡ Expires today" />

                    <View
                        android:layout_width="8dp"
                        android:layout_height="0dp" />

                    <TextView
                        android:id="@+id/tvDetailTagVerified"
                        style="@style/Widget.Humania.Tag.Blue"
                        android:text="✅ Verified donor" />

                </LinearLayout>

                <!-- Description -->
                <TextView
                    android:id="@+id/tvDetailDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="A mix of fresh spinach, lettuce, cabbage, and carrots. Harvested this morning from our garden — too much for one family! Please pick up before 6PM today. Available for 1 family only."
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.7"
                    android:layout_marginBottom="20dp" />

                <!-- Donor Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_donor_card"
                    android:padding="14dp"
                    android:layout_marginBottom="20dp">

                    <!-- Donor Avatar -->
                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_avatar_green"
                        android:layout_marginEnd="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="😊"
                            android:textSize="22sp" />
                    </FrameLayout>

                    <!-- Donor Info -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvDonorName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ana Lim"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="✅ Verified"
                                android:textColor="@color/green_primary"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvDonorReputation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ 4.9 · 34 donations · Member since 2024"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp" />

                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── CTA BUTTONS (Fixed Bottom) ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@color/surface"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp"
        android:elevation="8dp">

        <!-- Chat Button -->
        <Button
            android:id="@+id/btnChat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="💬 Chat"
            android:textColor="@color/surface"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_chat"
            android:paddingTop="16dp"
            android:backgroundTint="@color/green_light"
            android:paddingBottom="16dp" />

        <!-- Request Pickup Button -->
        <Button
            android:id="@+id/btnRequestPickup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="Request Pickup"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_primary"
            android:paddingTop="16dp"
            android:paddingBottom="16dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
