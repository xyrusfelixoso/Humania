<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_donate.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ── HEADER ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="56dp"
        android:paddingBottom="20dp"
        android:elevation="2dp">

        <!-- Back Button -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="@color/green_primary"
            android:textSize="22sp"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Post a Donation"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="serif" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Help someone today"
            android:textColor="@color/text_muted"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- ── SCROLLABLE FORM ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="32dp">

            <!-- Photo Upload Zone -->
            <LinearLayout
                android:id="@+id/uploadZone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_upload_zone"
                android:padding="32dp"
                android:layout_marginBottom="20dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📸"
                    android:textSize="40sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Add Photos"
                    android:textColor="@color/green_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Tap to upload up to 5 photos"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Category Selection -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CATEGORY"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp" />

            <!-- Horizontal Flow using a horizontal LinearLayout with wrapping is not possible
                 Switching to standard horizontal layout with margins for now. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/catFood"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🥦 Food"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_chip_active"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/catClothes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👕 Clothes"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_chip"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/catItems"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📦 Items"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_chip"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/catToys"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🧸 Toys"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_chip"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Title Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TITLE"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etTitle"
                style="@style/Widget.Humania.Input"
                android:hint="e.g. Fresh vegetables bundle"
                android:inputType="textCapSentences"
                android:layout_marginBottom="16dp" />

            <!-- Description Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DESCRIPTION"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etDescription"
                style="@style/Widget.Humania.Input"
                android:hint="Describe what you're donating…"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="3"
                android:gravity="top|start"
                android:layout_marginBottom="16dp" />

            <!-- Quantity Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QUANTITY"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etQuantity"
                style="@style/Widget.Humania.Input"
                android:hint="e.g. 2 bags, 5 items"
                android:inputType="text"
                android:layout_marginBottom="16dp" />

            <!-- Expiry Date Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXPIRY / AVAILABLE UNTIL"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etExpiry"
                style="@style/Widget.Humania.Input"
                android:hint="Select date"
                android:inputType="date"
                android:focusable="false"
                android:clickable="true"
                android:layout_marginBottom="16dp" />

            <!-- Pickup Location Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PICKUP LOCATION"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etLocation"
                style="@style/Widget.Humania.Input"
                android:hint="📍 Your address or public meet point"
                android:inputType="textPostalAddress"
                android:layout_marginBottom="24dp" />

            <!-- Submit Button -->
            <Button
                android:id="@+id/btnPostDonation"
                style="@style/Widget.Humania.Button.Primary"
                android:text="🎁 Post Donation" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
